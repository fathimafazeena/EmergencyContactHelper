<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission for making phone calls -->
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Emergency Contact Helper"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmergencyContactHelperr">

        <!-- Login Screen (Launcher Activity) -->
        <activity
            android:name="com.example.emergencycontacthelperr.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.example.emergencycontacthelperr.ForgotPasswordActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.OTPActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.ResetPasswordActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.SuccessActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.RegisterActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.DashboardActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.ContactListActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.AddContactActivity"/>
        <activity android:name="com.example.emergencycontacthelperr.QuickAccessActivity"/>

    </application>

</manifest>